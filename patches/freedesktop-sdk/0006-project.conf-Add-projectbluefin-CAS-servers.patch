From d7a91824155ea488cf59f03f1871d9a0b5c0ca55 Mon Sep 17 00:00:00 2001
From: Hec <hec@heccraft.com>
Date: Thu, 28 May 2026 01:07:37 -0400
Subject: [PATCH 6/9] project.conf: Add projectbluefin CAS servers

---
 project.conf | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/project.conf b/project.conf
index 80ebc447a..6c0179241 100644
--- a/project.conf
+++ b/project.conf
@@ -165,6 +165,12 @@ artifacts:
     retry-limit: 5
     retry-delay: 500
     request-timeout: 180
+- url: https://cache.projectbluefin.io:11001
+  connection-config:
+    keepalive-time: 60
+    retry-limit: 5
+    retry-delay: 500
+    request-timeout: 180
 
 source-caches:
 - url: https://cache.freedesktop-sdk.io:11001
@@ -179,6 +185,12 @@ source-caches:
     retry-limit: 5
     retry-delay: 500
     request-timeout: 180
+- url: https://cache.projectbluefin.io:11001
+  connection-config:
+    keepalive-time: 60
+    retry-limit: 5
+    retry-delay: 500
+    request-timeout: 180
 
 sandbox:
   build-arch: '%{target_arch}'
