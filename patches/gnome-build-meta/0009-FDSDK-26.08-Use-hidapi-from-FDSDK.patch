 - sdk/glib.bst
-- sdk/hidapi.bst
+- freedesktop-sdk.bst:components/hidapi.bst
 - freedesktop-sdk.bst:components/libevdev.bst
 - freedesktop-sdk.bst:components/libgudev.bst
 - freedesktop-sdk.bst:public-stacks/runtime-minimal.bst
diff --git a/elements/sdk/libmanette.bst b/elements/sdk/libmanette.bst
index 4e553df56..def979a8c 100644
--- a/elements/sdk/libmanette.bst
+++ b/elements/sdk/libmanette.bst
@@ -13,8 +13,8 @@ build-depends:
 
 depends:
 - sdk/glib.bst
-- sdk/hidapi.bst
 - sdk/libadwaita.bst
+- freedesktop-sdk.bst:components/hidapi.bst
 - freedesktop-sdk.bst:components/libevdev.bst
 - freedesktop-sdk.bst:components/libgudev.bst
 - freedesktop-sdk.bst:public-stacks/runtime-minimal.bst
