From f354a4510add771f5770ead1e94952434d09fb66 Mon Sep 17 00:00:00 2001
From: Sam Thursfield <sam.thursfield@codethink.co.uk>
Date: Fri, 24 Apr 2026 13:08:51 +0100
Subject: [PATCH 05/12] FDSDK 26.08: Fix Linux path

The Linux install path changed since FDSDK 25.08.
---
 elements/gnomeos/initramfs/signed-modules.bst | 2 +-
 elements/gnomeos/signed-boot.bst              | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/elements/gnomeos/initramfs/signed-modules.bst b/elements/gnomeos/initramfs/signed-modules.bst
index ebdfa7cb1..87b265ff7 100644
--- a/elements/gnomeos/initramfs/signed-modules.bst
+++ b/elements/gnomeos/initramfs/signed-modules.bst
@@ -15,7 +15,7 @@ config:
 
   - |
     version="$(ls -1 /usr/lib/modules | head -n1)"
-    cp /boot/vmlinuz "%{install-root}/usr/lib/modules/${version}"
+    cp /usr/lib/modules/${version}/vmlinuz "%{install-root}/usr/lib/modules/${version}"
 
   - |
     openssl x509 -inform PEM -outform DER -in "linux-module-cert.crt" -out "linux-module-cert.cer"
diff --git a/elements/gnomeos/signed-boot.bst b/elements/gnomeos/signed-boot.bst
index bbfda4eaf..b67cd9231 100644
--- a/elements/gnomeos/signed-boot.bst
+++ b/elements/gnomeos/signed-boot.bst
@@ -120,7 +120,7 @@ config:
       --phases="enter-initrd:leave-initrd" \
       --secureboot-private-key=VENDOR.key \
       --secureboot-certificate=VENDOR.crt \
-      --linux="/boot/vmlinuz" \
+      --linux="/usr/lib/modules/${version}/vmlinuz" \
       --initrd="/usr/lib/modules/${version}/initramfs.img" \
       --join-profile="profile-safe-mode.efi" \
       "${MICROCODE[@]}" "${DEVICETREES[@]}"
-- 
2.54.0

