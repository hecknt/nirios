 elements/gnomeos/replace-signed-systemd-boot.bst | 2 +-
 elements/gnomeos/signed-boot-common.bst          | 2 +-
 elements/gnomeos/signed-boot.bst                 | 2 +-
 10 files changed, 10 insertions(+), 10 deletions(-)

