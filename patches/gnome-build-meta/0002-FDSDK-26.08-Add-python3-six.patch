From 506d4fd9ed2fbfd67ab3e80264fd27a0a36f47df Mon Sep 17 00:00:00 2001
From: Sam Thursfield <sam.thursfield@codethink.co.uk>
Date: Wed, 20 May 2026 12:44:29 +0100
Subject: [PATCH 02/16] FDSDK 26.08: Add python3-six

This element was included in FDSDK 25.08, but in the upcoming 26.08
release it was removed as nothing used it any more. One component in
GNOME still uses it though (spice-gtk).

Change proposed separately in
https://gitlab.gnome.org/GNOME/gnome-build-meta/-/merge_requests/4743
---
 elements/core-deps/python3-six.bst | 13 +++++++++++++
 elements/core-deps/spice-gtk.bst   |  2 +-
 2 files changed, 14 insertions(+), 1 deletion(-)
 create mode 100644 elements/core-deps/python3-six.bst

diff --git a/elements/core-deps/python3-six.bst b/elements/core-deps/python3-six.bst
new file mode 100644
index 000000000..58733df5d
--- /dev/null
+++ b/elements/core-deps/python3-six.bst
@@ -0,0 +1,13 @@
+kind: pyproject
+
+build-depends:
+- freedesktop-sdk.bst:public-stacks/buildsystem-python-setuptools.bst
+
+depends:
+- freedesktop-sdk.bst:components/python3.bst
+
+sources:
+- kind: git_repo
+  url: github:benjaminp/six.git
+  track: "*.*.*"
+  ref: 1.17.0-0-gebd9b3af90247b8858d415a05e96e9ee61e48d07
diff --git a/elements/core-deps/spice-gtk.bst b/elements/core-deps/spice-gtk.bst
index 166b62c34..c13010f90 100644
--- a/elements/core-deps/spice-gtk.bst
+++ b/elements/core-deps/spice-gtk.bst
@@ -26,9 +26,9 @@ sources:
 
 build-depends:
 - core-deps/python-pyparsing.bst
+- core-deps/python3-six.bst
 - sdk/gtk-doc.bst
 - freedesktop-sdk.bst:components/perl.bst
-- freedesktop-sdk.bst:components/python3-six.bst
 - freedesktop-sdk.bst:components/sed.bst
 - freedesktop-sdk.bst:public-stacks/buildsystem-meson.bst
 
-- 
2.54.0

